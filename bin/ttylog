#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: ttylog [--name NAME] [--keys] -- <command> [args...]
       ttylog [--name NAME] <command> [args...]

Run an interactive command under script(1), saving terminal output to:
  ~/.local/state/ttylog/

This is a lightweight fallback for searchable Claude/Codex terminal history
without making tmux the default workflow. By default, typed keys are NOT logged.
Use --keys only when you accept that passwords and secrets may be captured.

Examples:
  ttylog --name claude-dotfiles -- claude
  ttylog --name codex-start -- codex
EOF
}

name=""
log_keys="false"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)
            if [[ $# -lt 2 ]]; then
                echo "--name requires a value" >&2
                exit 2
            fi
            name="$2"
            shift 2
            ;;
        --keys)
            log_keys="true"
            shift
            ;;
        --)
            shift
            break
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -eq 0 ]]; then
    usage >&2
    exit 2
fi

log_dir="${TTYLOG_DIR:-$HOME/.local/state/ttylog}"
mkdir -p "$log_dir"

if [[ -z "$name" ]]; then
    name="$(basename "$1")"
fi
safe_name="$(printf '%s' "$name" | tr -c 'A-Za-z0-9._-' '-')"
timestamp="$(date +%Y%m%d-%H%M%S)"
log_file="$log_dir/$timestamp-$safe_name.typescript"

echo "ttylog: $log_file" >&2
if [[ "$log_keys" == "true" ]]; then
    script -q -F -k "$log_file" "$@"
else
    script -q -F "$log_file" "$@"
fi
